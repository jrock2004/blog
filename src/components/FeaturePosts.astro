---
interface Props {
  count: number;
}

const allPosts = await Astro.glob('../pages/blog/*.md');

allPosts.sort((a, b) => {
  return Date.parse(b.frontmatter.date) - Date.parse(a.frontmatter.date);
});

const { count } = Astro.props;
---

<div>
  <h2 class="font-semibold text-xl mb-4">Latest Posts</h2>
  <div class="flex flex-col max-w-2xl mx-auto">
    {
      allPosts.slice(0, count).map((post: any) => {
        const title = post.frontmatter.title;
        const formattedDate = new Date(post.frontmatter.date).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });

        return (
          <a href={post.url} class="border-b py-4 px-1 flex hover:shadow-lg">
            <h3 class="text-lg">{title}</h3>
            <p class="ml-auto">{formattedDate}</p>
          </a>
        );
      })
    }
  </div>
</div>
