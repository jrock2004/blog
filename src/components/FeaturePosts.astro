---
interface Props {
  count: number;
}

const allPosts = await Astro.glob('../pages/blog/*.md');

allPosts.sort((a, b) => {
  return Date.parse(b.frontmatter.date) - Date.parse(a.frontmatter.date);
});

const { count } = Astro.props;
---

<div>
  <h2 class="font-semibold text-xl mb-4">Latest Posts</h2>
  <div class="flex flex-col mx-auto">
    {
      allPosts.slice(0, count).map((post: any) => {
        const title = post.frontmatter.title;
        const formattedDate = new Date(post.frontmatter.date).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });

        return (
          <a
            href={post.url}
            class="border-b py-4 px-1 flex hover:shadow-lg transition-all ease-in-out"
          >
            <div>
              <h3 class="text-lg mb-1">{title}</h3>
              <div>
                {post.frontmatter.tags.length > 0 && (
                  <div class="flex flex-wrap space-x-1">
                    {post.frontmatter.tags.map((tag: string) => (
                      <span class="text-xs border rounded-md px-4 py-1">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
            <p class="ml-auto">{formattedDate}</p>
          </a>
        );
      })
    }
  </div>
</div>
